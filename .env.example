# Flask
FLASK_ENV=production
FLASK_SECRET_KEY=change-me
FLASK_DEBUG=0
PORT=8000

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_CANDIDATE_IMAGE_BUCKET=candidate_images
SUPABASE_CANDIDATE_IMAGE_FOLDER=candidate_images

# App / session
SESSION_IDLE_TIMEOUT_SECONDS=10800
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax
TRUST_PROXY=1
MAX_UPLOAD_MB=5
SEND_FILE_MAX_AGE_DEFAULT=3600
API_CACHE_TTL_SECONDS=30
AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=30
REPORT_RATE_LIMIT_PER_MINUTE=20
SECURITY_HEADERS_ENABLED=1
CSRF_ORIGIN_CHECK=1
CSRF_TRUSTED_ORIGINS=
CSP_REPORT_ONLY=0
CSP_REPORT_URI=
ALLOW_FRAME_EMBED=0
HSTS_MAX_AGE_SECONDS=31536000
ALLOW_INSECURE_LOCAL_LOGIN_FALLBACK=0
